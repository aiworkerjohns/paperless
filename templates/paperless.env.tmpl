# ── Paperless-ngx Configuration ──

# REQUIRED: Random secret key (generated by installer)
PAPERLESS_SECRET_KEY=__SECRET_KEY__

# Database credentials (must match postgres.env)
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=__DB_PASS__

# URL - set to your Tailscale MagicDNS hostname once known
PAPERLESS_URL=__PAPERLESS_URL__

# Timezone
PAPERLESS_TIME_ZONE=__TIMEZONE__

# OCR language (eng = English, add others with + e.g. eng+deu)
PAPERLESS_OCR_LANGUAGE=eng

# OCR mode: skip if text layer exists, force to always re-OCR
PAPERLESS_OCR_MODE=skip

# Admin user (created on first run)
PAPERLESS_ADMIN_USER=__ADMIN_USER__
PAPERLESS_ADMIN_PASSWORD=__ADMIN_PASS__

# Consumption settings
PAPERLESS_CONSUMER_POLLING=30
PAPERLESS_CONSUMER_RECURSIVE=true

# File organization
PAPERLESS_FILENAME_FORMAT={created_year}/{document_type}/{correspondent} - {title}

# Task concurrency (adjust based on your Mac's CPU cores)
PAPERLESS_TASK_WORKERS=2
PAPERLESS_THREADS_PER_WORKER=2

# ── Reverse proxy settings (Tailscale Serve) ──
PAPERLESS_USE_X_FORWARD_HOST=true
PAPERLESS_USE_X_FORWARD_PORT=true
PAPERLESS_PROXY_SSL_HEADER=["HTTP_X_FORWARDED_PROTO", "https"]
PAPERLESS_CSRF_TRUSTED_ORIGINS=__CSRF_ORIGINS__

# ── Google SSO (optional — leave blank to disable) ──
PAPERLESS_APPS=__GOOGLE_SSO_APPS__
PAPERLESS_SOCIALACCOUNT_PROVIDERS=__GOOGLE_SSO_PROVIDERS__
