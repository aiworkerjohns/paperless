services:
  # ──────────────────────────────────────────────
  # Core: Paperless-ngx
  # ──────────────────────────────────────────────
  paperless:
    image: ghcr.io/paperless-ngx/paperless-ngx:latest
    container_name: paperless
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
      broker:
        condition: service_healthy
      gotenberg:
        condition: service_started
      tika:
        condition: service_started
    entrypoint: /custom-init/inject-overrides.sh
    ports:
      - "8000:8000"
    volumes:
      - paperless_data:/usr/src/paperless/data
      - paperless_media:/usr/src/paperless/media
      - ./overrides.js:/custom-init/overrides.js:ro
      - ./inject-overrides.sh:/custom-init/inject-overrides.sh:ro
      - ./export:/usr/src/paperless/export
      - ./consume:/usr/src/paperless/consume
    env_file: paperless.env
    environment:
      PAPERLESS_REDIS: redis://broker:6379
      PAPERLESS_DBHOST: db
      PAPERLESS_DBENGINE: postgresql
      PAPERLESS_TIKA_ENABLED: 1
      PAPERLESS_TIKA_ENDPOINT: http://tika:9998
      PAPERLESS_TIKA_GOTENBERG_ENDPOINT: http://gotenberg:3000

  # ──────────────────────────────────────────────
  # Database: PostgreSQL
  # ──────────────────────────────────────────────
  db:
    image: docker.io/library/postgres:16
    container_name: paperless-db
    restart: unless-stopped
    volumes:
      - pgdata:/var/lib/postgresql/data
    env_file: postgres.env
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U paperless"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ──────────────────────────────────────────────
  # Message Broker: Redis
  # ──────────────────────────────────────────────
  broker:
    image: docker.io/library/redis:7
    container_name: paperless-redis
    restart: unless-stopped
    volumes:
      - redisdata:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ──────────────────────────────────────────────
  # Document Conversion: Gotenberg
  # ──────────────────────────────────────────────
  gotenberg:
    image: docker.io/gotenberg/gotenberg:8
    container_name: paperless-gotenberg
    restart: unless-stopped
    command:
      - "gotenberg"
      - "--chromium-disable-javascript=true"
      - "--chromium-allow-list=file:///tmp/.*"

  # ──────────────────────────────────────────────
  # Metadata Extraction: Apache Tika
  # ──────────────────────────────────────────────
  tika:
    image: docker.io/apache/tika:latest
    container_name: paperless-tika
    restart: unless-stopped

  # ──────────────────────────────────────────────
  # AI: paperless-ai (auto-tagging & classification)
  # ──────────────────────────────────────────────
  paperless-ai:
    image: clusterzx/paperless-ai:latest
    container_name: paperless-ai
    restart: unless-stopped
    depends_on:
      - paperless
    ports:
      - "3000:3000"
    volumes:
      - paperless_ai_data:/app/data
      - ./patch-paperless-ai.sh:/custom-init/patch-paperless-ai.sh:ro
    command: /custom-init/patch-paperless-ai.sh
    env_file: paperless-ai.env

  # ──────────────────────────────────────────────
  # AI: paperless-gpt (vision model OCR)
  # ──────────────────────────────────────────────
  paperless-gpt:
    image: icereed/paperless-gpt:latest
    container_name: paperless-gpt
    restart: unless-stopped
    depends_on:
      - paperless
    ports:
      - "3002:8080"
    volumes:
      - paperless_gpt_prompts:/app/prompts
    env_file: paperless-gpt.env

  # ──────────────────────────────────────────────
  # Ollama Management: Open WebUI
  # ──────────────────────────────────────────────
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: open-webui
    restart: unless-stopped
    ports:
      - "3001:8080"
    volumes:
      - open_webui_data:/app/backend/data
    environment:
      OLLAMA_BASE_URL: http://host.docker.internal:11434

  # ──────────────────────────────────────────────
  # Scheduled Tasks: Duplicate Sweep (midnight daily)
  # ──────────────────────────────────────────────
  cron:
    image: docker.io/library/python:3.12-alpine
    container_name: paperless-cron
    restart: unless-stopped
    depends_on:
      - paperless
      - paperless-ai
    volumes:
      - ./duplicate-sweep.py:/scripts/duplicate-sweep.py:ro
    environment:
      PAPERLESS_URL: http://paperless:8000
      PAPERLESS_TOKEN: __PAPERLESS_TOKEN__
      AI_URL: http://paperless-ai:3000
      AI_API_KEY: __AI_API_KEY__
    entrypoint: /bin/sh
    command:
      - -c
      - |
        echo "0 0 * * * python3 /scripts/duplicate-sweep.py >> /proc/1/fd/1 2>&1" | crontab -
        echo "[cron] Duplicate sweep scheduled for midnight daily"
        crond -f -l 2

  # ──────────────────────────────────────────────
  # Logging: Dozzle
  # ──────────────────────────────────────────────
  dozzle:
    image: amir20/dozzle:latest
    container_name: dozzle
    restart: unless-stopped
    ports:
      - "8080:8080"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro

volumes:
  paperless_data:
  paperless_media:
  pgdata:
  redisdata:
  paperless_ai_data:
  paperless_gpt_prompts:
  open_webui_data:
