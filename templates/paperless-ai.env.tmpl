# ── paperless-ai Configuration ──

# Paperless-ngx connection
PAPERLESS_API_URL=http://paperless:8000/api
PAPERLESS_API_TOKEN=__PAPERLESS_TOKEN__
PAPERLESS_USERNAME=__ADMIN_USER__

# AI provider: ollama, openai, deepseek, gemini, azure, openrouter, custom
AI_PROVIDER=ollama

# Ollama settings (native Mac Ollama via Docker host)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TOKEN_LIMIT=4096
OLLAMA_TOKEN_RESPONSE=2048

# Scan interval in minutes
SCAN_INTERVAL=30

# Processing settings
ADD_AI_TAG=yes
AI_TAG_NAME=ai-processed
USE_EXISTING_TAGS=yes
USE_EXISTING_CORRESPONDENTS=yes
PROCESS_PREDEFINED_DOCUMENTS=no

# Features to enable
ASSIGN_TAGS=yes
DETECT_CORRESPONDENTS=yes
DOCUMENT_TYPE_CLASSIFICATION=yes
TITLE_GENERATION=yes
CUSTOM_FIELDS=no

# Timezone
TZ=__TIMEZONE__

# RAG (document chat) - enables /api/rag endpoints
RAG_SERVICE_ENABLED=true

# API key for headless access (used by overrides.js chat panel)
API_KEY=__AI_API_KEY__

# Port
PAPERLESS_AI_PORT=3000
