# ── paperless-gpt Configuration ──

# Paperless-ngx connection
PAPERLESS_BASE_URL=http://paperless:8000
PAPERLESS_API_TOKEN=__PAPERLESS_TOKEN__

# LLM provider for text analysis: ollama, openai
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b

# Ollama connection (native Mac Ollama via Docker host)
OLLAMA_HOST=http://host.docker.internal:11434

# OCR settings - use LLM vision model for OCR
OCR_PROVIDER=llm

# Vision LLM for OCR (minicpm-v is recommended for accuracy)
VISION_LLM_PROVIDER=ollama
VISION_LLM_MODEL=minicpm-v

# Auto-processing tags (create these tags in Paperless-ngx)
AUTO_TAG=paperless-gpt-auto
AUTO_OCR_TAG=paperless-gpt-ocr-auto

# Manual processing tag
MANUAL_TAG=paperless-gpt-manual

# Log level
LOG_LEVEL=info
