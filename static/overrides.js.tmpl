    '    </button>',
    '    <a id="ai-chat-settings" href="' + AI_BASE + '" target="_blank" title="AI Settings">',
    '      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',
    '    </a>',
    '    <button id="ai-chat-close" title="Close">&times;</button>',
    '  </div>',
    '</div>',
    '<div style="position:relative;flex:1;display:flex;flex-direction:column;overflow:hidden">',
    '  <div id="ai-chat-messages"></div>',
    '  <div id="ai-convo-list">',
    '    <div id="ai-convo-list-header">',
    '      <div style="display:flex;align-items:center;gap:8px">',
    '        <button id="ai-convo-back" title="Back">',
    '          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>',
    '        </button>',
    '        <h3>Chats</h3>',
    '      </div>',
    '      <button id="ai-convo-new-btn" title="New chat">+ New</button>',
    '    </div>',
    '    <div id="ai-convo-items"></div>',
    '  </div>',
    '</div>',
    '<div id="ai-chat-status"></div>',
    '<div id="ai-chat-input-area">',
    '  <textarea id="ai-chat-input" placeholder="Ask about your documents..." rows="1"></textarea>',
    '  <button id="ai-chat-send">Send</button>',
    '</div>'
  ].join("\n");
  document.body.appendChild(panel);

  var messagesEl = document.getElementById("ai-chat-messages");
  var input = document.getElementById("ai-chat-input");
  var sendBtn = document.getElementById("ai-chat-send");
  var statusEl = document.getElementById("ai-chat-status");
  var convoListEl = document.getElementById("ai-convo-list");
  var convoItemsEl = document.getElementById("ai-convo-items");

  // --- Render a message to the DOM ---
  function renderMessage(entry) {
    if (entry.role === "typing") return;
    var div = document.createElement("div");
    div.className = "ai-msg " + entry.role;
    div.textContent = entry.text;

    if (entry.sources && entry.sources.length > 0) {
      var sourcesDiv = document.createElement("div");
      sourcesDiv.className = "sources";
      sourcesDiv.innerHTML = entry.sources.map(function (s) {
        return '<a href="/documents/' + s.id + '/details">' + s.title + '</a>';
      }).join("<br>");
      div.appendChild(sourcesDiv);
    }

    messagesEl.appendChild(div);
    return div;
  }

  // --- Restore chat from active conversation ---
  function restoreChat() {
    messagesEl.innerHTML = "";
    if (chatLog.length === 0) {
      var welcome = document.createElement("div");
      welcome.className = "ai-msg assistant";
      welcome.textContent = "Hi! Ask me anything about your documents.";
      messagesEl.appendChild(welcome);
    } else {
      chatLog.forEach(function (entry) { renderMessage(entry); });
    }
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  restoreChat();

  // --- Toggle panel ---
  function openPanel() {
    panel.classList.add("open");
    fab.style.display = "none";
    savePanelState(true);
    // Start a new conversation if none active
    if (!getActiveId()) {
      newConversation();
    }
    input.focus();
    checkIndexStatus();
  }

  function closePanel() {
    panel.classList.remove("open");
    fab.style.display = "flex";
    savePanelState(false);
    closeConvoList();
  }

  fab.addEventListener("click", openPanel);
  document.getElementById("ai-chat-close").addEventListener("click", closePanel);
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      if (convoListEl.classList.contains("open")) {
        closeConvoList();
      } else if (panel.classList.contains("open")) {
        closePanel();
      }
    }
  });

  // --- Click outside to close ---
  document.addEventListener("click", function (e) {
    if (!panel.classList.contains("open")) return;
    // Ignore clicks on the panel itself or the FAB
    if (panel.contains(e.target) || fab.contains(e.target)) return;
    closePanel();
  });

  // Restore panel state after page navigation
  if (wasPanelOpen()) {
    setTimeout(openPanel, 300);
  }

  // --- Conversation list ---
  function openConvoList() {
    renderConvoList();
    convoListEl.classList.add("open");
  }

  function closeConvoList() {
    convoListEl.classList.remove("open");
  }

  function formatTime(ts) {
    var d = new Date(ts);
    var now = new Date();
    var diff = now - d;
    if (diff < 60000) return "just now";
    if (diff < 3600000) return Math.floor(diff / 60000) + "m ago";
    if (diff < 86400000) return Math.floor(diff / 3600000) + "h ago";
    return d.toLocaleDateString();
  }

  function renderConvoList() {
    var convos = loadConversations();
    var activeId = getActiveId();
    convoItemsEl.innerHTML = "";

    if (convos.length === 0) {
      var empty = document.createElement("div");
      empty.className = "ai-convo-empty";
      empty.textContent = "No conversations yet";
      convoItemsEl.appendChild(empty);
      return;
    }

    convos.forEach(function (c) {
      var item = document.createElement("div");
      item.className = "ai-convo-item" + (c.id === activeId ? " active" : "");

      var textDiv = document.createElement("div");
      textDiv.className = "ai-convo-item-text";

      var titleEl = document.createElement("div");
      titleEl.className = "ai-convo-item-title";
      titleEl.textContent = c.title;

      var metaEl = document.createElement("div");
      metaEl.className = "ai-convo-item-meta";
      var msgCount = c.messages.filter(function(m) { return m.role === "user"; }).length;
      metaEl.textContent = msgCount + " message" + (msgCount !== 1 ? "s" : "") + " · " + formatTime(c.created);

      textDiv.appendChild(titleEl);
      textDiv.appendChild(metaEl);

      var deleteBtn = document.createElement("button");
      deleteBtn.className = "ai-convo-delete";
      deleteBtn.title = "Delete chat";
      deleteBtn.innerHTML = "&times;";
      deleteBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        deleteConversation(c.id);
      });

      item.appendChild(textDiv);
      item.appendChild(deleteBtn);
      item.addEventListener("click", function () {
        switchConversation(c.id);
      });

      convoItemsEl.appendChild(item);
    });
  }

  function switchConversation(id) {
    setActiveId(id);
    var convo = getActiveConvo();
    chatLog = convo ? convo.messages : [];
    restoreChat();
    closeConvoList();
    input.focus();
  }

  function deleteConversation(id) {
    var convos = loadConversations();
    convos = convos.filter(function (c) { return c.id !== id; });
    saveConversations(convos);

    if (getActiveId() === id) {
      if (convos.length > 0) {
        switchConversation(convos[0].id);
      } else {
        setActiveId(null);
        chatLog = [];
        restoreChat();
      }
    }
    renderConvoList();
  }

  document.getElementById("ai-chat-new").addEventListener("click", newConversation);
  document.getElementById("ai-chat-hamburger").addEventListener("click", function () {
    if (convoListEl.classList.contains("open")) {
      closeConvoList();
    } else {
      openConvoList();
    }
  });
  document.getElementById("ai-convo-back").addEventListener("click", closeConvoList);
  document.getElementById("ai-convo-new-btn").addEventListener("click", newConversation);

  // --- Reprocess all documents ---
  document.getElementById("ai-chat-reprocess").addEventListener("click", function () {
    if (!confirm("Reprocess all documents with AI?\n\nThis will reset processing history, immediately re-scan all documents, and rebuild the RAG index.")) return;
    var btn = this;
    btn.style.opacity = "0.3";
    btn.disabled = true;
    addAndSave("Resetting processing history...", "assistant");
    fetch(AI_BASE + "/api/reset-all-documents", {
      method: "POST",
      headers: { "x-api-key": API_KEY },
    })
      .then(function (r) { return r.json(); })
      .then(function (resetResult) {
        if (!resetResult.success) throw new Error("Failed to reset processing history");
        // Fire scan (don't await — it blocks until all docs processed)
        // RAG reindex is triggered automatically after scan completes (via patch-paperless-ai.sh)
        fetch(AI_BASE + "/api/scan/now", {
          method: "POST",
          headers: { "x-api-key": API_KEY },
        }).catch(function () {});
        addAndSave("Scan triggered. All documents are being reprocessed — RAG index will rebuild automatically when done.", "assistant");
        setTimeout(checkIndexStatus, 60000);
      })
      .catch(function (err) {
        addAndSave("Error: " + err.message, "error");
      })
      .finally(function () {
        btn.style.opacity = "";
        btn.disabled = false;
      });
  });

  // --- Auto-resize textarea ---
  input.addEventListener("input", function () {
    this.style.height = "auto";
    this.style.height = Math.min(this.scrollHeight, 100) + "px";
  });

  // --- Index status ---
  function checkIndexStatus() {
    fetch(AI_BASE + "/api/rag/index/status", {
      headers: { "x-api-key": API_KEY },
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.documents_count === 0) {
          statusEl.textContent = "Indexing in progress...";
        } else {
          statusEl.textContent = data.documents_count + " documents indexed";
        }
      })
      .catch(function () {
        statusEl.textContent = "AI service unavailable";
      });
  }

  // --- Filter sources: deduplicate and format ---
  function filterSources(sources, answer) {
    if (!sources || sources.length === 0) return [];
    var seen = {};
    var filtered = [];
    for (var i = 0; i < sources.length; i++) {
      var s = sources[i];
      var id = s.doc_id || s.id || s.document_id;
      if (!id || seen[id]) continue;
      var title = s.title || ("Document #" + id);
      seen[id] = true;
      filtered.push({ id: id, title: title });
      if (filtered.length >= 5) break;
    }
    return filtered;
  }

  // --- Chat ---
  function addAndSave(text, role, sources) {
    var entry = { text: text, role: role };
    if (sources && sources.length > 0) entry.sources = sources;
    chatLog.push(entry);

    // Ensure an active conversation exists
    if (!getActiveId()) {
      newConversation();
    }

    // Update title from first user message
    if (role === "user") {
      var convos = loadConversations();
      var activeId = getActiveId();
      for (var i = 0; i < convos.length; i++) {
        if (convos[i].id === activeId && convos[i].title === "New chat") {
          convos[i].title = text.length > 50 ? text.substring(0, 47) + "..." : text;
          saveConversations(convos);
          break;
        }
      }
    }

    saveActiveMessages(chatLog);
    renderMessage(entry);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // --- Progress indicator ---
  function showProgress(text) {
    removeProgress();
    var div = document.createElement("div");
    div.className = "ai-typing-dots";
    div.id = "ai-progress";
    var label = document.createElement("span");
    label.style.cssText = "font-size:13px;color:var(--bs-secondary-color,#999);margin-right:8px;animation:none;width:auto;height:auto;background:none;border-radius:0";
    label.textContent = text;
    div.innerHTML = "";
    div.appendChild(label);
    var dots = document.createElement("span");
    dots.innerHTML = '<span></span><span></span><span></span>';
    dots.style.cssText = "display:flex;gap:4px";
    dots.querySelectorAll("span").forEach(function(s, i) {
      s.style.cssText = "width:6px;height:6px;border-radius:50%;background:var(--bs-secondary-color,#999);display:inline-block;animation:ai-dots 1.4s infinite both;animation-delay:" + (i * 0.2) + "s";
    });
    div.appendChild(dots);
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeProgress() {
    var el = document.getElementById("ai-progress");
    if (el) el.remove();
  }

  // --- Two-phase chat: search first, then answer ---
  function sendMessage() {
    var question = input.value.trim();
    if (!question) return;

    addAndSave(question, "user");
    input.value = "";
    input.style.height = "auto";
    sendBtn.disabled = true;

    // Phase 1: Quick search to show matched documents
    showProgress("Searching documents");

    fetch(AI_BASE + "/api/rag/search", {
      method: "POST",
      headers: { "Content-Type": "application/json", "x-api-key": API_KEY },
      body: JSON.stringify({ query: question }),
    })
      .then(function (r) { return r.ok ? r.json() : []; })
      .then(function (searchResults) {
        var results = Array.isArray(searchResults) ? searchResults : (searchResults.results || []);
        var topScore = results.length > 0 ? (results[0].score || 0) : 0;
        var threshold = topScore * 0.3;
        var relevant = results.filter(function(r) { return (r.score || 0) > threshold && (r.score || 0) > 0.05; });
        var count = relevant.length;
        if (count > 0) {
          showProgress("Found " + count + " doc" + (count > 1 ? "s" : "") + ", generating answer");
        } else {
          showProgress("Generating answer");
        }

        // Phase 2: Get the full AI answer
        return fetch(AI_BASE + "/api/rag/ask", {
          method: "POST",
          headers: { "Content-Type": "application/json", "x-api-key": API_KEY },
          body: JSON.stringify({ question: question }),
        });
      })
      .then(function (r) {
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      })
      .then(function (data) {
        removeProgress();
        var answer = data.answer || data.response || data.message || JSON.stringify(data);
        var rawSources = data.sources || data.documents || data.context || [];
        var sources = filterSources(rawSources, answer);
        addAndSave(answer, "assistant", sources);
      })
      .catch(function (err) {
        removeProgress();
        addAndSave("Error: " + err.message, "error");
      })
      .finally(function () {
        sendBtn.disabled = false;
        input.focus();
      });
  }

  sendBtn.addEventListener("click", sendMessage);
  input.addEventListener("keydown", function (e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // --- Auto-dismiss "Document changes detected" dialog ---
  // Background AI/workflow processing updates docs while viewing them,
  // triggering a version conflict warning. Auto-click "discard" to suppress it.
  var dismissObserver = new MutationObserver(function (mutations) {
    for (var i = 0; i < mutations.length; i++) {
      var nodes = mutations[i].addedNodes;
      for (var j = 0; j < nodes.length; j++) {
        var node = nodes[j];
        if (node.nodeType !== 1) continue;
        // Look for the modal dialog containing "Document changes detected"
        var modal = node.classList && node.classList.contains("modal-backdrop")
          ? document.querySelector(".modal-dialog")
          : node.querySelector ? node.querySelector(".modal-dialog") : null;
        if (!modal) {
          if (node.classList && node.classList.contains("modal")) modal = node.querySelector(".modal-dialog");
        }
        if (!modal) continue;
        var title = modal.textContent || "";
        if (title.indexOf("Document changes detected") !== -1 || title.indexOf("changes detected") !== -1) {
          // Find and click the discard/close button
          var buttons = modal.querySelectorAll("button");
          for (var k = 0; k < buttons.length; k++) {
            var btnText = (buttons[k].textContent || "").trim().toLowerCase();
            if (btnText === "discard" || btnText === "close" || btnText.indexOf("discard") !== -1) {
              buttons[k].click();
              return;
            }
          }
          // Fallback: click the X close button
          var closeBtn = modal.querySelector("[aria-label='Close'], .btn-close, .close");
          if (closeBtn) closeBtn.click();
        }
      }
    }
  });
  dismissObserver.observe(document.body, { childList: true, subtree: true });

  // --- Duplicate document indicator ---
  // Watches for document detail pages and shows a banner if tagged possible-duplicate
  var PAPERLESS_TOKEN = "__PAPERLESS_TOKEN__";
  var dupeLastDocId = null;

  function checkForDuplicate() {
    // Match URL: /documents/123/details
    var match = window.location.href.match(/\/documents\/(\d+)\/details/);
    if (!match) {
      removeDupeBanner();
      dupeLastDocId = null;
      return;
    }
    var docId = match[1];
    if (docId === dupeLastDocId) return; // already checked
    dupeLastDocId = docId;
    removeDupeBanner();

    // Fetch document to check tags
    fetch("/api/documents/" + docId + "/", {
      headers: { "Authorization": "Token " + PAPERLESS_TOKEN }
    })
      .then(function (r) { return r.json(); })
      .then(function (doc) {
        // Check if it has the possible-duplicate tag
        // We need the tag ID — fetch it once and cache
        return getDupeTagId().then(function (dupeTagId) {
          if (!dupeTagId || doc.tags.indexOf(dupeTagId) === -1) return;
          // Fetch notes to find original doc link
          return fetch("/api/documents/" + docId + "/notes/", {
            headers: { "Authorization": "Token " + PAPERLESS_TOKEN }
          })
            .then(function (r) { return r.json(); })
            .then(function (notesData) {
              var notes = Array.isArray(notesData) ? notesData : (notesData.results || []);
              var origId = null;
              var origTitle = null;
              for (var i = 0; i < notes.length; i++) {
                var noteMatch = notes[i].note.match(/Duplicate of document #(\d+): (.+)/);
                if (noteMatch) {
                  origId = noteMatch[1];
                  origTitle = noteMatch[2].split("\n")[0];
                  break;
                }
              }
              showDupeBanner(docId, origId, origTitle);
            });
        });
      })
      .catch(function () { /* ignore */ });
  }

  var dupeTagIdCache = null;
  function getDupeTagId() {
    if (dupeTagIdCache) return Promise.resolve(dupeTagIdCache);
    return fetch("/api/tags/?name__iexact=possible-duplicate", {
      headers: { "Authorization": "Token " + PAPERLESS_TOKEN }
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var results = data.results || [];
        if (results.length > 0) dupeTagIdCache = results[0].id;
        return dupeTagIdCache;
      })
      .catch(function () { return null; });
  }

  function showDupeBanner(docId, origId, origTitle) {
    removeDupeBanner();
    var banner = document.createElement("div");
    banner.id = "ai-dupe-banner";
    // Warning triangle icon
    banner.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
    var text = document.createElement("span");
    if (origId && origTitle) {
      text.innerHTML = 'Possible duplicate of <a href="/documents/' + origId + '/details">' + origTitle + '</a>';
    } else {
      text.textContent = "This document may be a duplicate";
    }
    banner.appendChild(text);

    // Insert into the document detail view
    insertBanner(banner);
  }

  function insertBanner(banner) {
    var attempts = 0;
    function tryInsert() {
      var titleBar = document.querySelector("pngx-document-detail .col");
      if (!titleBar) titleBar = document.querySelector("pngx-document-detail h1, pngx-document-detail .page-header");
      if (!titleBar) titleBar = document.querySelector("[class*='document-detail'] .col, app-document-detail .col");
      if (!titleBar) titleBar = document.querySelector("pngx-document-detail");
      if (titleBar) {
        var parent = titleBar.closest("pngx-document-detail") || titleBar.parentNode;
        if (parent) {
          parent.insertBefore(banner, parent.firstChild);
          return;
        }
      }
      if (attempts++ < 10) setTimeout(tryInsert, 300);
    }
    tryInsert();
  }

  function removeDupeBanner() {
    var el = document.getElementById("ai-dupe-banner");
    if (el) el.remove();
  }

  // Poll for route changes (Angular SPA doesn't fire popstate reliably)
  var lastUrl = window.location.href;
  setInterval(function () {
    if (window.location.href !== lastUrl) {
      lastUrl = window.location.href;
      checkForDuplicate();
    }
  }, 500);

  // Initial check
  checkForDuplicate();
})();
