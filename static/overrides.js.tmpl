    "}",
    "#ai-chat-send:hover { background: var(--pngx-primary-darken-5); }",
    "#ai-chat-send:disabled { opacity: 0.5; cursor: not-allowed; }",
    "#ai-chat-status {",
    "  padding: 6px 16px; font-size: 11px; text-align: center;",
    "  color: var(--bs-secondary-color, #999); flex-shrink: 0;",
    "}",
    "@media (max-width: 500px) { #ai-chat-panel { width: 100vw; right: -100vw; } }",
    // Duplicate indicator banner
    "#ai-dupe-banner {",
    "  display: flex; align-items: center; gap: 10px; padding: 8px 16px;",
    "  background: var(--bs-warning-bg-subtle, #fff3cd); color: var(--bs-warning-text-emphasis, #664d03);",
    "  border: 1px solid var(--bs-warning-border-subtle, #ffecb5); border-radius: 8px;",
    "  margin: 0 16px 12px 16px; font-size: 13px;",
    "}",
    "#ai-dupe-banner svg { flex-shrink: 0; }",
    "#ai-dupe-banner a {",
    "  color: var(--bs-warning-text-emphasis, #664d03); font-weight: 600;",
    "  text-decoration: underline; text-underline-offset: 2px;",
    "}",
    "#ai-dupe-banner a:hover { opacity: 0.8; }"
  ].join("\n");
  document.head.appendChild(style);

  // --- Multi-conversation storage ---
  function genId() {
    return Date.now().toString(36) + Math.random().toString(36).substr(2, 5);
  }

  function loadConversations() {
    try {
      var data = sessionStorage.getItem(CONVOS_KEY);
      return data ? JSON.parse(data) : [];
    } catch (e) { return []; }
  }

  function saveConversations(convos) {
    try {
      sessionStorage.setItem(CONVOS_KEY, JSON.stringify(convos));
    } catch (e) { /* ignore */ }
  }

  function getActiveId() {
    return sessionStorage.getItem(ACTIVE_KEY) || null;
  }

  function setActiveId(id) {
    if (id) {
      sessionStorage.setItem(ACTIVE_KEY, id);
    } else {
      sessionStorage.removeItem(ACTIVE_KEY);
    }
  }

  function savePanelState(isOpen) {
    sessionStorage.setItem(PANEL_STATE_KEY, isOpen ? "1" : "0");
  }

  function wasPanelOpen() {
    return sessionStorage.getItem(PANEL_STATE_KEY) === "1";
  }

  // Migrate old single-chat storage to new format
  function migrateOldStorage() {
    var old = sessionStorage.getItem("ai-chat-history");
    if (old) {
      try {
        var messages = JSON.parse(old);
        if (messages.length > 0) {
          var firstQ = messages.find(function(m) { return m.role === "user"; });
          var title = firstQ ? firstQ.text.substring(0, 50) : "Previous chat";
          var convo = { id: genId(), title: title, messages: messages, created: Date.now() };
          var convos = loadConversations();
          convos.unshift(convo);
          saveConversations(convos);
          setActiveId(convo.id);
        }
      } catch (e) { /* ignore */ }
      sessionStorage.removeItem("ai-chat-history");
    }
  }

  migrateOldStorage();

  // Get active conversation (or null)
  function getActiveConvo() {
    var id = getActiveId();
    if (!id) return null;
    var convos = loadConversations();
    for (var i = 0; i < convos.length; i++) {
      if (convos[i].id === id) return convos[i];
    }
    return null;
  }

  // Save messages to active conversation
  function saveActiveMessages(messages) {
    var id = getActiveId();
    if (!id) return;
    var convos = loadConversations();
    for (var i = 0; i < convos.length; i++) {
      if (convos[i].id === id) {
        convos[i].messages = messages;
        break;
      }
    }
    saveConversations(convos);
  }

  // Create new conversation and make it active
  function newConversation() {
    var convo = { id: genId(), title: "New chat", messages: [], created: Date.now() };
    var convos = loadConversations();
    convos.unshift(convo);
    saveConversations(convos);
    setActiveId(convo.id);
    chatLog = [];
    restoreChat();
    closeConvoList();
  }

  // In-memory chat log
  var chatLog = [];
  var activeConvo = getActiveConvo();
  if (activeConvo) {
    chatLog = activeConvo.messages;
  }

  // --- DOM ---
  var fab = document.createElement("button");
  fab.id = "ai-chat-fab";
  fab.title = "Ask AI about your documents";
  fab.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>';
  document.body.appendChild(fab);

  var panel = document.createElement("div");
  panel.id = "ai-chat-panel";
  panel.innerHTML = [
    '<div id="ai-chat-header">',
    '  <div id="ai-chat-header-left">',
    '    <button id="ai-chat-hamburger" title="Chat history">',
    '      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>',
    '    </button>',
    '    <h3>Ask AI</h3>',
